NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/negotiation-copilot
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Required for simulations. No spaces around =. No quotes needed (quotes are stripped if present).
XAI_API_KEY=
XAI_MODEL=grok-2-latest
# Alternative provider (Groq):
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional: explicit provider endpoint (default shown here)
# XAI_BASE_URL=https://api.x.ai/v1
# Backward compatibility (optional): LLM_* names are also supported
# LLM_MODEL=grok-2-latest
# LLM_BASE_URL=https://api.x.ai/v1
# Set true to always use offline simulation (no API calls).
# USE_MOCK_AI=false
# Must match the URL you use in the browser (include port if not 80), e.g. http://localhost:5174
CLIENT_URL=http://localhost:5173
