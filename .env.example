# Optional: full API origin when not using Vite dev proxy (e.g. production build)
VITE_API_URL=

# Dev: where Vite proxies /api (default http://127.0.0.1:5000). Change if the API uses another port.
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# Dev server port (default 5173). Match CLIENT_URL in server/.env
# VITE_PORT=5173
